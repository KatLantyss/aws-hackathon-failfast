# AWS 配置
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_SESSION_TOKEN=your_session_token  # 臨時憑證需要

# S3 Data Lake
S3_DATA_BUCKET=ship-datalake-hackathon
S3_RAW_PREFIX=raw/

# DynamoDB（待部署）
DYNAMODB_SPEED_LOSS=ship-analysis-dev-speed-loss-cache
DYNAMODB_PREDICTIONS=ship-analysis-dev-predictions-cache
DYNAMODB_MAINTENANCE=ship-analysis-dev-maintenance-cache
DYNAMODB_API_CACHE=ship-analysis-dev-api-cache

# 應用配置
ENVIRONMENT=dev
LOG_LEVEL=INFO
CACHE_TTL_SECONDS=3600
MODEL_VERSION=v1.0.0
ENABLE_XRAY=false
