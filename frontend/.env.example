# Copy to .env and fill in real values. Never commit .env.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional overrides
ANTHROPIC_MODEL=claude-sonnet-5
OPENAI_STT_MODEL=gpt-4o-transcribe

# Backend API base URL
# 本機開發：http://localhost:8000（make dev-api 啟動後）
# 生產環境：https://d1yvzz0da29zvi.cloudfront.net
VITE_BACKEND_BASE_URL=http://localhost:8000

# Dev-only data-source inspector — overlays a REAL/HYBRID/STUB/UNREACHABLE
# badge on each data block, with hover/click detail on the API field mapping.
# Off by default.
VITE_DEBUG_DATA_SOURCE=false
