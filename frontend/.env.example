# AWS AI provider used by POST /api/nlu. This is server-side only; never expose
# AWS credentials through VITE_* variables or commit them to the repository.
AI_PROVIDER=bedrock
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# Optional AgentCore mode. Set AI_PROVIDER=agentcore only after deploying a
# compatible AgentCore runtime that accepts the NluRequest payload and returns
# a JSON NluResult. The ECS task role/local AWS profile needs
# bedrock-agentcore:InvokeAgentRuntime.
AGENTCORE_RUNTIME_ARN=
AGENTCORE_QUALIFIER=

# Voice transcription remains an independent OpenAI service. Leave blank to
# disable STT; typed assistant requests still use Bedrock/AgentCore.
OPENAI_API_KEY=
OPENAI_STT_MODEL=gpt-4o-transcribe

# Backend API base URL
# Local development: http://localhost:8000 (make dev starts it)
# Production: https://d1yvzz0da29zvi.cloudfront.net
VITE_BACKEND_BASE_URL=http://localhost:8000

# Dev-only data-source inspector — overlays a REAL/HYBRID/STUB/UNREACHABLE
# badge on each data block, with hover/click detail on the API field mapping.
# Off by default.
VITE_DEBUG_DATA_SOURCE=false
