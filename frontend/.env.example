# The Dashboard NLU endpoint uses AgentCore Runtime server-side only. Never
# expose AWS credentials through VITE_* variables or commit them to the repository.
AI_PROVIDER=agentcore
AWS_REGION=us-east-1
AGENTCORE_RUNTIME_ARN=
AGENTCORE_QUALIFIER=

# Voice transcription remains an independent OpenAI service. Leave blank to
# disable STT; typed assistant requests use AgentCore Runtime.
OPENAI_API_KEY=
OPENAI_STT_MODEL=gpt-4o-transcribe

# Backend API base URL
# Local development: http://localhost:8000 (make dev starts it)
# Production: https://d1yvzz0da29zvi.cloudfront.net
VITE_BACKEND_BASE_URL=http://localhost:8000

# Dev-only data-source inspector — overlays a REAL/HYBRID/STUB/UNREACHABLE
# badge on each data block, with hover/click detail on the API field mapping.
# Off by default.
VITE_DEBUG_DATA_SOURCE=false
